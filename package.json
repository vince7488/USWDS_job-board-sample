{
  "name": "uswds-sample-job-board",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm --workspace frontend run dev",
    "build": "npm --workspace frontend run build",
    "preview": "npm --workspace frontend run preview",
    "supabase:init": "npm --workspace backend run supabase:init",
    "supabase:start": "npm --workspace backend run supabase:start",
    "supabase:stop": "npm --workspace backend run supabase:stop",
    "supabase:status": "npm --workspace backend run supabase:status",
    "db:reset": "npm --workspace backend run db:reset"
  }
}